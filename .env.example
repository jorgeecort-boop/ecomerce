# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://ecomerce:ecomerce_dev@localhost:5432/ecomerce"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_URL="amqp://ecomerce:ecomerce_dev@localhost:5672"

# ============================================
# JWT (CHANGE THESE IN PRODUCTION!)
# ============================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================
# E2E TEST SEEDING (leave UNSET in production unless intentional)
# ============================================
# When set, exposes POST /test-seed/create-user gated by header
# X-E2E-Seed-Token. Used by Playwright authenticated flows to
# provision test users (vendor-test@ecomerce.com / customer-test@ecomerce.com).
# Generate with: openssl rand -hex 32
E2E_SEED_TOKEN=""

# ============================================
# MERCADOPAGO PAYMENTS (LatAm)
# ============================================
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."
MERCADOPAGO_PUBLIC_KEY="APP_USR-..."
MERCADOPAGO_CLIENT_ID=""
MERCADOPAGO_CLIENT_SECRET=""

# ============================================
# STRIPE PAYMENTS
# ============================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ============================================
# SHOPIFY INTEGRATION
# ============================================
SHOPIFY_API_KEY=""
SHOPIFY_STORE_URL=""
SHOPIFY_API_SECRET=""
SHOPIFY_ACCESS_TOKEN=""

# ============================================
# APP CONFIG
# ============================================
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ============================================
# SUPPLIERS
